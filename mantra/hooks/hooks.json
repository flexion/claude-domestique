{
  "description": "Mantra behavior hook - injects anti-sycophancy and critical assessment rules on every prompt",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/behavior.js",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/behavior.js",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
